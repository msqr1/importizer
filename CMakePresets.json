{
  "version": 10,
  "configurePresets": [
    {
      "name": "ci-windows",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER=": "clang-cl",
        "CMAKE_CXX_COMPILER=": "clang-cl"
      }
    },
    {
      "name": "ci-linux",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-22",
        "CMAKE_CXX_COMPILER": "clang++-22"
      }
    },
    {
      "name": "ci-macos",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm@22/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm@22/bin/clang++",
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/llvm@22"
      }
    },
    {
      "name": "my-linux",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_C_COMPILER": "clang-22",
        "CMAKE_CXX_COMPILER": "clang++-22"
      }
    },
    {
      "name": "my-windows",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    }
  ]
}
